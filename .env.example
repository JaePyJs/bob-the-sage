# =========================
# Backend configuration
# =========================

# External APIs (replace with real keys in .env, NEVER commit)
DEEPL_API_KEY=your_deepl_key_here
SEMANTIC_SCHOLAR_API_KEY=your_semantic_scholar_key_here

# CORS allowed origins (comma-separated)
ALLOWED_ORIGINS=http://localhost:3000,https://sage-research.vercel.app

# External API rate limiting
ARXIV_DELAY_SECONDS=3
S2_REQUESTS_PER_SECOND=1

# =========================
# Frontend configuration
# =========================

# Backend base URL (dev)
NEXT_PUBLIC_API_URL=http://localhost:8000

# WebSocket base URL (dev)
NEXT_PUBLIC_WS_URL=ws://localhost:8000